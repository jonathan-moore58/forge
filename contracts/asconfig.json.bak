{
    "targets": {
        "factory": {
            "outFile": "build/NFTFactory.wasm",
            "textFile": "build/NFTFactory.wat",
            "abort": "index-factory/abort"
        },
        "collection": {
            "outFile": "build/CollectionTemplate.wasm",
            "textFile": "build/CollectionTemplate.wat",
            "abort": "index-collection/abort"
        },
        "marketplace": {
            "outFile": "build/Marketplace.wasm",
            "textFile": "build/Marketplace.wat",
            "abort": "index-marketplace/abort"
        },
        "auction": {
            "outFile": "build/AuctionHouse.wasm",
            "textFile": "build/AuctionHouse.wat",
            "abort": "index-auction/abort"
        },
        "staking": {
            "outFile": "build/StakingRewards.wasm",
            "textFile": "build/StakingRewards.wat",
            "abort": "index-staking/abort"
        },
        "registry": {
            "outFile": "build/CollectionRegistry.wasm",
            "textFile": "build/CollectionRegistry.wat",
            "abort": "index-registry/abort"
        }
    },
    "options": {
        "transform": "@btc-vision/opnet-transform",
        "sourceMap": false,
        "optimizeLevel": 3,
        "shrinkLevel": 1,
        "converge": true,
        "noAssert": false,
        "runtime": "stub",
        "memoryBase": 0,
        "initialMemory": 1,
        "exportStart": "start"
    }
}
